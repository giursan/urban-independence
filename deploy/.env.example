# Copy to deploy/.env on the NAS and fill real values.

# Public URL served by ngrok. On ngrok Free this is generated after startup.
# Keep this as a placeholder until you copy the real URL from `docker compose logs ngrok`.
PUBLIC_ORIGIN=https://replace-after-ngrok-starts.ngrok-free.app
NGROK_AUTHTOKEN=your-ngrok-authtoken

# LAN-only debug port for the Caddy gateway on the NAS. Ngrok talks to the
# gateway over Docker's internal network, so this only needs to be free locally.
GATEWAY_PORT=8088

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# App secrets/settings
DEV_USER_ID=00000000-0000-0000-0000-000000000001
IDENTITY_SECRET=replace-with-a-long-random-string
IOS_DEMO_TOKEN=replace-with-a-long-random-string-for-iphone-demo

# Optional integrations
FIRECRAWL_API_KEY=
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CAREGIVER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Voice settings
VOICE_TTS_VOICE=Polly.Joanna-Neural
VOICE_TTS_RATE=95%
VOICE_SENTENCE_PAUSE_MS=350
