# ============================================================================
# Companion — environment variables
#
# Copy this file and fill in real values for each app:
#   cp .env.example apps/api/.env          # backend  (FastAPI)
#   cp .env.example apps/web/.env.local    # frontend (Next.js)
#
# Each app only reads the variables relevant to it; extra ones are ignored,
# so the same template works for both copies.
# ============================================================================

# ---- OpenAI (apps/api) -----------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector(N) dimension in supabase/migrations/0001_init.sql.
# text-embedding-3-small = 1536. Change both together if you swap models.
EMBEDDING_DIM=1536

# ---- Supabase (apps/api — server-side) -------------------------------------
# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Secret — server only. Bypasses RLS; used solely for the public share endpoint.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings → API → JWT Settings → JWT Secret (HS256)
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- CORS (apps/api) -------------------------------------------------------
# Comma-separated list of allowed web origins.
ALLOWED_ORIGINS=http://localhost:3000

# ---- Telegram (apps/api) ---------------------------------------------------
# Create a bot with @BotFather. Webhook URL: https://<api-origin>/telegram/webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CAREGIVER_CHAT_ID=optional-caregiver-chat-id
TELEGRAM_WEBHOOK_SECRET=optional-shared-secret-token

# ---- Web (apps/web — exposed to the browser, NEXT_PUBLIC_ prefix) ----------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
